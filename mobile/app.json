{
  "expo": {
    "name": "MateSync",
    "slug": "matesync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "matesync",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0d17",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matesync.app"
    },
    "android": {
      "package": "com.matesync.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "MateSync a besoin d'accéder à tes photos pour choisir ta photo de profil.",
          "cameraPermission": "MateSync a besoin de la caméra pour prendre ta photo de profil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0d17",
          "image": "./assets/splash-blank.png",
          "imageWidth": 1
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01bb11ed-2096-41d1-8e37-5f686e7755c4"
      }
    },
    "owner": "v4l3nt1n"
  }
}
