{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "matesync-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "matesync-mobile",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--tunnel"],
      "cwd": "mobile",
      "port": 8081
    },
    {
      "name": "matesync-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "cwd": "mobile",
      "port": 8082
    }
  ]
}
